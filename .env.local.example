# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (required for login, portal, owner, crew) ---
# Dashboard: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role: only for server/webhook (keep secret). Needed for Stripe webhook → create jobs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Stripe (keys are NOT fixed in code — you rotate them in Dashboard; app reads process.env) ---
# Dashboard: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY must be either:
#   - Standard secret key: sk_test_... or sk_live_...
#   - Restricted key (works if it has Checkout Sessions → Write): rk_test_... or rk_live_...
# Do NOT put publishable keys (pk_), webhook secrets (whsec_), or random IDs (e.g. mk_) here.
# Use test keys locally; live keys only when you intend to charge real cards.
# Price is calculated in app (dynamic) — you do not need a fixed Stripe Price ID for checkout.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional until you add Elements: publishable key (client-side only — never use as STRIPE_SECRET_KEY)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Google Maps (optional — maps show a list fallback without this) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Optional: server-only key for Geocoding API (recommended in production). Falls back to NEXT_PUBLIC key.
GOOGLE_MAPS_SERVER_API_KEY=
# Map fallbacks when ZIP/team data is missing (Portland defaults)
NEXT_PUBLIC_DEFAULT_SERVICE_ZIP=97209
NEXT_PUBLIC_DEFAULT_SERVICE_LAT=45.5231
NEXT_PUBLIC_DEFAULT_SERVICE_LNG=-122.6765

# Used in Stripe success/cancel URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Google Business review link — makes hero stat + “Read reviews on Google” clickable on homepage
# NEXT_PUBLIC_GOOGLE_REVIEW_URL=https://g.page/r/...

# Optional: Homepage hero image — full URL or path under /public (e.g. /marketing/hero.jpg). Defaults to a stock image if unset.
# NEXT_PUBLIC_HOME_HERO_IMAGE_URL=/marketing/hero.jpg

# Crew pay (optional — defaults 20% pool, split 2 ways). Restart dev after change.
NEXT_PUBLIC_COMMISSION_POOL_PERCENT=20
NEXT_PUBLIC_CREW_SPLIT_WAYS=2

# --- Twilio SMS (optional — crew job alerts to profiles.phone) ---
# Dashboard: https://console.twilio.com/ — use E.164-capable From number (Messaging service or your Twilio #)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
